{
  "name": "@pathway/zh-cn",
  "version": "0.1.0",
  "description": "Pathway Chinese address parser",
  "license": "MIT",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "jest"
  },
  "dependencies": {
    "@pathway/core": "workspace:*",
    "@pathway/zh-cn-data": "workspace:*"
  },
  "devDependencies": {
    "@types/jest": "*",
    "jest": "*",
    "ts-jest": "*",
    "tsup": "*",
    "typescript": "*"
  },
  "jest": {
    "moduleNameMapper": {
      "^@pathway/core$": "<rootDir>/../../../core/pathway-core/src/index.ts",
      "^@pathway/zh-cn-data$": "<rootDir>/../pathway-zh-cn-data/src/index.ts"
    },
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/*.test.ts"
    ]
  }
}
